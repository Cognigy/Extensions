{
  "name": "aws",
  "version": "4.0.1",
  "description": "Integrates with Amazon Web Services",
  "main": "build/module.js",
  "scripts": {
    "transpile": "tsc -p .",
    "zip": "tar cfz aws.tar.gz build/* package.json package-lock.json .npmrc README.md icon.png",
    "build": "npm run transpile && npm run lint && npm run zip",
    "lint": "tslint -c tslint.json src/**/*.ts"
  },
  "keywords": [
    "AWS",
    "Polly"
  ],
  "author": "Cognigy GmbH",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.974.0",
    "@cognigy/extension-tools": "^0.17.0-rc3",
    "@langchain/classic": "^1.0.19",
    "@langchain/community": "1.1.18",
    "@langchain/core": "1.1.28",
    "@langchain/textsplitters": "1.0.1",
    "aws-sdk": "2.1693.0",
    "d3-dsv": "^2.0.0",
    "csv-parse": "6.1.0",
    "mammoth": "1.11.0",
    "officeparser": "^4.2.0",
    "pdf-parse": "1.1.1"
  },
  "devDependencies": {
    "tslint": "6.1.3",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3"
  }
}
