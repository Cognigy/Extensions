{
  "name": "microsoft-sharepoint",
  "version": "5.0.0",
  "description": "Sharepoint integration for Cognigy.AI",
  "main": "build/module.js",
  "scripts": {
    "transpile": "tsc -p .",
    "zip": "tar cfz microsoft-sharepoint.tar.gz build/* package.json package-lock.json README.md icon.png",
    "build": "npm run transpile && npm run lint && npm run zip",
    "lint": "tslint -c tslint.json 'src/**/*.ts'"
  },
  "keywords": [
    "Microsoft",
    "Sharepoint"
  ],
  "author": "Cognigy GmbH",
  "license": "MIT",
  "dependencies": {
    "@cognigy/extension-tools": "^0.17.0-rc3",
    "@langchain/community": "1.1.14",
    "@langchain/core": "1.1.28",
    "@langchain/textsplitters": "1.0.1",
    "langchain": "1.2.27",
    "d3-dsv": "^2.0.0",
    "mammoth": "^1.5.1",
    "pdf-parse": "^1.1.1",
    "officeparser": "^4.2.0",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "tslint": "^6.1.2",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
