{
	"name": "salesforce",
	"version": "4.5.1",
	"description": "This Extension integrates with all Salesforce Clouds",
	"authors": "Matt Muller <https://github.com/Mattallmighty>",
	"main": "build/module.js",
	"scripts": {
		"transpile": "tsc -p .",
		"zip": "tar cfz salesforce.tar.gz build/* package.json package-lock.json README.md icon.png",
		"build": "npm run transpile && npm run lint && npm run zip",
		"lint": "tslint -c tslint.json src/**/*.ts"
	},
	"keywords": [
		"Salesforce",
		"Service",
		"Marketing",
		"Sales",
		"Commerce"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/Cognigy/Extensions"
	},
	"author": "Cognigy GmbH",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^10.17.60",
		"@types/qs": "^6.9.17",
		"dotenv": "^17.3.1",
		"ts-node": "^10.9.2",
		"tslint": "^6.1.2",
		"typescript": "^4.9.5"
	},
	"dependencies": {
		"@cognigy/extension-tools": "^0.17.0",
		"axios": "^1.13.5"
	}
}
